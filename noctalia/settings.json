        "capsuleOpacity": 0.09,
        "contentPadding": 0,
        "density": "default",
        "displayMode": "always_visible",
        "enableExclusionZoneInset": true,
        "fontScale": 1.02,
        "frameRadius": 12,
        "frameThickness": 8,
        "hideOnOverview": false,
        "marginHorizontal": 12,
        "marginVertical": 4,
        "middleClickAction": "none",
