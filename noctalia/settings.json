        "spectrumMirrored": true,
        "visualizerType": "linear",
        "volumeFeedback": false,
        "volumeFeedbackSoundFile": "",
        "volumeOverdrive": true,
        "volumeStep": 5
    },
    "bar": {
        "autoHideDelay": 500,
        "autoShowDelay": 150,
        "backgroundOpacity": 0.4,
        "barType": "floating",
