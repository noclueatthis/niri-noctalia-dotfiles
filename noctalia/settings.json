        "middleClickFollowMouse": false,
        "monitors": [],
        "mouseWheelAction": "none",
        "mouseWheelWrap": true,
        "outerCorners": false,
        "position": "top",
        "reverseScroll": false,
        "rightClickAction": "settings",
        "rightClickCommand": "",
